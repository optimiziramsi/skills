# migration staging — per-project .claude copies + review notes; not part of the marketplace
_review/

# This repo tracks its own working continuity — .agent/ (memory, handoff, lessons) and the root
# .todo / .todo-inbox — like an ordinary project. Only machine-local or path-bearing artifacts stay
# ignored. Flow runner scratch/logs are excluded because job logs embed absolute session paths.
.agent/loop/
.agent/grind/

# machine-local Claude settings (registers this checkout as a directory marketplace to dogfood it)
.claude/settings.local.json

# Python bytecode from running the flow runners
__pycache__/
*.pyc

# OS cruft
.DS_Store

.idea/
