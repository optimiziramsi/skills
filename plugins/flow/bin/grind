#!/usr/bin/env python3
"""grind — the flow grind runner.

Runs ONE mission file (`.agent/grind/<topic>.md`) as the SAME prompt N times. Each iteration
is a fresh headless Claude session that reads the mission's cross-iteration log (its only
memory), picks 1–few new items per the mission's picking rules, commits them, and appends
a block to the log. Loops until the mission flips to `status: done`, a `done-check` passes,
or a cap is hit. The runner never commits — the executing agent owns all git operations.

Mission filenames MUST match `YYMMDD_HHMMSS_{topic}.md` (6+6 datetime prefix); anything
else is rejected — the prefix is what makes the topic, log stem, and commit tags stable.

Resilience (all per-iteration, state survives runner restarts):
  watchdog        wall-clock cap per iteration (default 900s, FLOW_ITER_TIMEOUT_SECS;
                  0 disables) — SIGTERM, then SIGKILL after 10s; routed to a backoff retry
  dirty-tree guard  refuses to START a fresh iteration on uncommitted changes; if the dirt
                  is a previous session's interrupted iteration, auto-resumes via the
                  retry path instead of halting
  retry state     `.attempt` file — up to 4 attempts per iteration; retries get a
                  continuation prompt (inspect the partial state, then finish / revert /
                  skip the in-flight item), and `GRIND_ATTEMPT` is exported to the agent
  productivity gate  an iteration only advances when the tree is clean AND it produced a
                  tagged commit or flipped the mission status; anything else burns an
                  attempt or (for transient API errors / fast crashes) a long backoff
  transient backoff  known API-error signatures in the output (429/5xx/overloaded/quota/
                  network) sleep 10–60 min without burning the attempt budget (6 max)

Usage:
  grind <mission.md> [options]

Options:
  --once             run exactly one fresh iteration and stop
  --count N          run at most N fresh iterations this session, then stop
  --status           show mission status, iteration + attempt counters, log tail; exit
  --dry-run          show what one iteration would run, execute nothing
  --reset            clear the iteration + attempt counters and flip status back to active
  -y, --yes          skip the arm-confirmation (for unattended/cron runs)
  --dir DIR          mission directory (default: .agent/grind)
  -h, --help         this help

Mission frontmatter (see the `grind` skill for the full spec):
  status: active|done|paused    title: ...    model: opus|sonnet
  max-turns: 40   effort: xhigh|max   (both passed to the CLI when it supports the flags)
  scope-hint: 1-3 items
  max-iterations: 40   done-check: "<shell cmd; exit 0 = mission complete>"

Env escape hatches: CLAUDE_BIN, FLOW_ALLOW_NESTED=1, FLOW_CLAUDE_PERMISSION_MODE,
FLOW_ITER_TIMEOUT_SECS, FLOW_LONG_BACKOFF_BASE, FLOW_ITER_PAUSE_SECS.
"""
import os
import re
import subprocess
import sys
import time

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import _flowlib as fl  # noqa: E402

HARD_CAP = 500  # absolute runtime cap regardless of max-iterations
MAX_ITER_ATTEMPTS = 4          # 1 initial + 3 retries per iteration
MAX_TRANSIENT_RETRIES = 6      # long backoffs before giving up (~3.5h at default base)
FAST_FAIL_SECS = 30            # < this with a clean tree + no commit = assumed transient
DEFAULT_ITER_TIMEOUT_SECS = 900  # wall-clock watchdog per iteration
MISSION_NAME_RE = re.compile(r"^[0-9]{6}_[0-9]{6}_.+\.md$")
GITIGNORE_BODY = (
    "# transient per-mission state — not worth committing\n"
    "# (the mission .md, its .log memory, and runner_*.log overview ARE worth keeping)\n"
    "*.iter\n*.attempt\n.lint-baseline.txt\n*.jsonl\n*.run.log\n"
)


def parse_args(argv):
    opts = {"mission": None, "once": False, "count": None, "status": False,
            "dry_run": False, "reset": False, "yes": False, "dir": ".agent/grind"}
    it = iter(argv)
    for a in it:
        if a in ("-h", "--help"):
            print(__doc__)
            sys.exit(0)
        elif a == "--once":
            opts["once"] = True
        elif a == "--count":
            try:
                opts["count"] = int(next(it))
            except (StopIteration, ValueError):
                fl.die("--count needs an integer argument")
            if opts["count"] < 1:
                fl.die("--count must be >= 1")
        elif a == "--status":
            opts["status"] = True
        elif a == "--dry-run":
            opts["dry_run"] = True
        elif a == "--reset":
            opts["reset"] = True
        elif a in ("-y", "--yes"):
            opts["yes"] = True
        elif a == "--dir":
            opts["dir"] = next(it)
        elif a.startswith("-"):
            fl.die(f"unknown argument: {a} (try --help)")
        elif opts["mission"] is None:
            opts["mission"] = a
        else:
            fl.die(f"unexpected extra argument: {a}")
    return opts


def resolve_mission(opts):
    m = opts["mission"]
    if not m:
        fl.die("no mission file given. Usage: grind <mission.md>  (try --help)")
    candidates = [m, os.path.join(opts["dir"], m),
                  os.path.join(opts["dir"], os.path.basename(m))]
    path = None
    for c in candidates:
        if os.path.isfile(c):
            path = c
            break
    if path is None:
        fl.die(f"mission file not found: {m} (looked in ./ and {opts['dir']}/)")
    base = os.path.basename(path)
    if not MISSION_NAME_RE.match(base):
        fl.die(
            f"mission filename `{base}` does not match the `YYMMDD_HHMMSS_{{topic}}.md` "
            "convention (6+6 datetime prefix from `date '+%y%m%d_%H%M%S'`). Rename it — "
            "the prefix keeps the topic, log stem, and commit tags stable."
        )
    return path


def _state_path(mission_path, job_dir, ext):
    stem = os.path.splitext(os.path.basename(mission_path))[0]
    return os.path.join(job_dir, f"{stem}.{ext}")


def _read_counter(path):
    try:
        with open(path) as fh:
            return int(fh.read().strip() or "0")
    except (OSError, ValueError):
        return 0


def _write_counter(path, n):
    with open(path, "w") as fh:
        fh.write(str(n) + "\n")


def read_iter(mission_path, job_dir):
    return _read_counter(_state_path(mission_path, job_dir, "iter"))


def write_iter(mission_path, job_dir, n):
    _write_counter(_state_path(mission_path, job_dir, "iter"), n)


def read_attempt(mission_path, job_dir):
    """0 = fresh iteration next; > 0 = the current iteration is mid-retry. Persisted so
    retry state survives runner restarts (Ctrl+C mid-retry, crash, dirty-tree resume)."""
    return _read_counter(_state_path(mission_path, job_dir, "attempt"))


def write_attempt(mission_path, job_dir, n):
    _write_counter(_state_path(mission_path, job_dir, "attempt"), n)


def ensure_gitignore(job_dir):
    gi = os.path.join(job_dir, ".gitignore")
    if not os.path.exists(gi):
        with open(gi, "w") as fh:
            fh.write(GITIGNORE_BODY)


def dirty_tree(job_dir, stem):
    """Return dirty `git status --porcelain` lines, excluding runner-owned files.

    Excluded: the mission's memory log (created empty pre-run, grows via the agent),
    the runner's own transcript/state files, and `runner_*.log` overviews — they are
    dirty BY the run, not meaningful work. Returns None when git is unavailable or
    this isn't a repo (guard disabled, fail-open).
    """
    try:
        top = subprocess.run(["git", "rev-parse", "--show-toplevel"],
                             capture_output=True, text=True)
        if top.returncode != 0:
            return None
        st = subprocess.run(["git", "status", "--porcelain"], capture_output=True, text=True)
        if st.returncode != 0:
            return None
    except Exception:  # noqa: BLE001 — guard must never break the run
        return None
    rel_dir = os.path.relpath(os.path.abspath(job_dir), top.stdout.strip()).replace(os.sep, "/")
    own = {f"{rel_dir}/{stem}.log", f"{rel_dir}/{stem}.run.log", f"{rel_dir}/{stem}.jsonl",
           f"{rel_dir}/{stem}.iter", f"{rel_dir}/{stem}.attempt", f"{rel_dir}/.gitignore"}
    dirty = []
    for line in st.stdout.splitlines():
        if len(line) < 4:
            continue
        path = line[3:]
        if " -> " in path:
            path = path.split(" -> ", 1)[1]
        path = path.strip().strip('"')
        if path in own:
            continue
        if (os.path.dirname(path) == rel_dir and
                os.path.basename(path).startswith("runner_") and path.endswith(".log")):
            continue
        dirty.append(line)
    return dirty


def tagged_commit_exists(topic, iteration):
    """Did any recent commit land with this iteration's `(grind: topic #N)` tag?"""
    try:
        out = subprocess.run(
            ["git", "log", "--oneline", "-50", "--fixed-strings",
             f"--grep=(grind: {topic} #{iteration})"],
            capture_output=True, text=True)
        return out.returncode == 0 and bool(out.stdout.strip())
    except Exception:  # noqa: BLE001
        return False


def run_done_check(cmd):
    """Return True if the mission's done-check passes (exit 0). No cmd → never done.

    shell=True is intentional and by-design: `done-check` is a shell one-liner the user
    authored in their OWN mission frontmatter (the documented examples use pipes, e.g.
    `grep -r TODO src/ | wc -l | awk '{exit ($1==0?0:1)}'`), so it needs shell semantics.
    It is not a trust boundary — the runner already executes the whole mission as an
    autonomous agent with full permissions, gated behind the explicit arm-confirmation.
    """
    if not cmd:
        return False
    try:
        return subprocess.run(cmd, shell=True).returncode == 0  # noqa: S602 — see docstring
    except Exception as e:  # noqa: BLE001
        fl.info(fl.yellow(f"  done-check errored ({e}); treating as not-done"))
        return False


def compose_prompt(mission_path, body, meta, iteration, topic, log_path):
    scope_hint = meta.get("scope-hint", "1-3 items")
    status_contract = (
        f"Read the mission log `{log_path}` FIRST — it is your ONLY memory of what prior "
        f"iterations did; skip anything already listed as done or fully scanned. Pick "
        f"{scope_hint} per the mission's picking rules, do the work, and commit each item "
        f"with a single-line message ending `(grind: {topic} #{iteration})`. Append one "
        f"iteration block to `{log_path}` summarizing what you did/scanned/deferred. If no "
        f"candidates remain, set the mission's frontmatter `status: done`. Do NOT "
        f"pre-enumerate or redo logged work; stay within the mission's out-of-scope list. "
        f"Leave the working tree CLEAN (everything committed) when you stop."
    )
    protocol = fl.EXECUTING_PROTOCOL.format(status_contract=status_contract)
    return (
        f"{protocol}\n\n"
        f"This is iteration #{iteration} of grind mission `{os.path.basename(mission_path)}` "
        f"(topic: {topic}). The mission definition follows.\n\n"
        f"--- BEGIN MISSION ---\n{body}\n--- END MISSION ---\n"
    )


def compose_retry_prompt(mission_path, body, meta, iteration, topic, log_path, attempt):
    """Continuation prompt for a retry attempt. The previous attempt for THIS iteration
    either produced no tagged commit, or left the working tree dirty mid-item. The agent
    inspects the partial state and decides: finish it, revert + restart, or revert + skip.
    """
    status_contract = (
        f"This is RETRY {attempt + 1}/{MAX_ITER_ATTEMPTS} of iteration #{iteration}. The "
        f"previous attempt either produced NO commit tagged `(grind: {topic} #{iteration})`, "
        f"or left the working tree DIRTY (partial mid-item work). FIRST run `git status`, "
        f"`git diff --stat`, and `git log --oneline -10` to see which case you're in. Then "
        f"read the mission log `{log_path}` for prior-iteration memory. Decide ONE of: "
        f"(a) FINISH the in-flight item — if the partial work is sound, complete it and "
        f"commit with the `(grind: {topic} #{iteration})` tag; "
        f"(b) REVERT + RESTART — if it's wrong or stuck, discard the partial changes "
        f"(careful: only the paths the previous attempt touched; never the mission's .log "
        f"or runner files) and do the item fresh; "
        f"(c) REVERT + SKIP — if the item is too complex, revert as in (b), record the "
        f"deferral with a one-line reason in the mission log, and commit that log update "
        f"with the tag. CRITICAL: the working tree MUST be clean (everything committed) "
        f"when you stop — the runner's dirty-tree guard blocks the next iteration "
        f"otherwise. Append/extend a log block noting this iteration took "
        f"{attempt + 1} attempts. Do NOT pick new items beyond the in-flight one."
    )
    protocol = fl.EXECUTING_PROTOCOL.format(status_contract=status_contract)
    return (
        f"{protocol}\n\n"
        f"This is a RETRY of iteration #{iteration} of grind mission "
        f"`{os.path.basename(mission_path)}` (topic: {topic}). The mission definition "
        f"follows for context — but your job is ONLY to resolve the in-flight item as "
        f"instructed above, not to pick new work.\n\n"
        f"--- BEGIN MISSION ---\n{body}\n--- END MISSION ---\n"
    )


def print_status(mission_path, job_dir, meta, iteration, attempt, mem_log):
    fl.info(fl.bold(f"\nmission: {os.path.basename(mission_path)}"))
    fl.info(f"  title:          {meta.get('title', '(none)')}")
    fl.info(f"  status:         {meta.get('status', '(none)')}")
    fl.info(f"  iterations run: {iteration}")
    fl.info(f"  max-iterations: {meta.get('max-iterations', '(default)')}  (hard cap {HARD_CAP})")
    if attempt > 0:
        fl.info(fl.yellow(
            f"  attempt:        {attempt + 1}/{MAX_ITER_ATTEMPTS} — next launch resumes "
            f"iteration #{iteration} as a retry (continuation prompt)"))
    dc = meta.get("done-check", "")
    if dc:
        passed = run_done_check(dc)
        fl.info(f"  done-check:     {'PASS (complete)' if passed else 'not yet'}  [{dc}]")
    try:
        with open(mem_log, encoding="utf-8") as fh:
            tail = fh.read().splitlines()[-20:]
        if tail:
            fl.info(fl.dim(f"\n  ── log tail ({os.path.basename(mem_log)}) ──"))
            for line in tail:
                fl.info(fl.dim(f"  {line}"))
    except OSError:
        pass
    fl.info("")


def arm_or_exit(opts, mission_path, meta):
    if opts["yes"]:
        return
    fl.info(fl.yellow(
        f"\n⚠ Mission '{meta.get('title', os.path.basename(mission_path))}' will run "
        f"UNATTENDED with full tool permissions ({fl.DEFAULT_PERMISSION_MODE}) — the agent "
        "edits files and runs git/shell commands with no prompts, looping until done."))
    if not sys.stdin.isatty():
        fl.die("not a TTY and -y not given — refusing to run unattended without explicit --yes.")
    try:
        ans = input("  Type 'yes' to proceed: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        fl.die("aborted.")
    if ans != "yes":
        fl.die("aborted.")


def main():
    opts = parse_args(sys.argv[1:])
    job_dir = opts["dir"]
    mission_path = resolve_mission(opts)
    stem = os.path.splitext(os.path.basename(mission_path))[0]
    topic = stem.split("_", 2)[-1]                             # drop YYMMDD_HHMMSS prefix
    mem_log = os.path.join(job_dir, f"{stem}.log")             # the agent's cross-iteration MEMORY
    transcript_log = os.path.join(job_dir, f"{stem}.run.log")  # runner transcript (kept OUT of memory)
    jsonl_path = os.path.join(job_dir, f"{stem}.jsonl")

    if opts["reset"]:
        for ext in ("iter", "attempt"):
            p = _state_path(mission_path, job_dir, ext)
            if os.path.exists(p):
                os.remove(p)
        meta, _, _ = fl.read_job(mission_path)
        if (meta.get("status") or "").strip().lower() != "active":
            fl.set_frontmatter_field(mission_path, "status", "active")
        fl.info(fl.green(f"reset {stem}: iteration + attempt counters cleared, status: active."))
        return

    meta, body, _ = fl.read_job(mission_path)
    iteration = read_iter(mission_path, job_dir)

    if opts["status"]:
        print_status(mission_path, job_dir, meta, iteration,
                     read_attempt(mission_path, job_dir), mem_log)
        return

    if opts["dry_run"]:
        fl.info(fl.bold(f"dry run — mission {stem}, next is iteration #{iteration + 1}"))
        fl.info(f"  status={meta.get('status')}  model={meta.get('model', fl.DEFAULT_MODEL)}  "
                f"scope-hint={meta.get('scope-hint', '1-3 items')}")
        fl.info(fl.dim("  would run the mission prompt as a fresh claude session; nothing executed."))
        return

    fl.nested_guard()
    fl.ensure_claude_available()

    status = (meta.get("status") or "active").strip().lower()
    if status != "active":
        fl.die(f"mission status is '{status}', not 'active'. Set status: active (or --reset) to run.")

    max_iterations = min(fl.coerce_int(meta, "max-iterations", 40), HARD_CAP)
    model = (meta.get("model") or fl.DEFAULT_MODEL).strip()
    done_check = meta.get("done-check", "")
    count_cap = 1 if opts["once"] else opts["count"]
    try:
        iter_timeout = float(os.environ.get("FLOW_ITER_TIMEOUT_SECS", DEFAULT_ITER_TIMEOUT_SECS))
    except ValueError:
        iter_timeout = DEFAULT_ITER_TIMEOUT_SECS
    try:
        iter_pause = float(os.environ.get("FLOW_ITER_PAUSE_SECS", 5))
    except ValueError:
        iter_pause = 5.0

    os.makedirs(job_dir, exist_ok=True)
    ensure_gitignore(job_dir)
    open(mem_log, "a").close()  # ensure the memory log exists for iteration 1

    arm_or_exit(opts, mission_path, meta)
    runner_log = os.path.join(job_dir, f"runner_{fl.stamp()}.log")
    fl.info(fl.dim(f"runner log: {runner_log}"))

    fresh_started = 0       # fresh iterations launched THIS session (caps + auto-resume)
    transient_retries = 0   # long-backoff budget (does not touch the attempt budget)
    pending_prompt = None   # carried across transient backoffs: relaunch the SAME
                            # iteration + attempt without re-running pre-flight

    while True:
        attempt = read_attempt(mission_path, job_dir)

        if pending_prompt is not None:
            prompt = pending_prompt
            pending_prompt = None
            fl.info(fl.bold(f"↻ iteration #{iteration}")
                    + fl.dim(f"  (relaunch after transient backoff, "
                             f"attempt {attempt + 1}/{MAX_ITER_ATTEMPTS})"))
        elif attempt == 0:
            # ── fresh iteration: full pre-flight ────────────────────────────
            if iteration >= max_iterations:
                fl.info(fl.yellow(f"reached max-iterations ({max_iterations}). Stopping."))
                fl.set_frontmatter_field(mission_path, "status", "done")
                break
            if count_cap is not None and fresh_started >= count_cap:
                fl.info(fl.dim(
                    "--once: stopping after one iteration." if opts["once"]
                    else f"--count {count_cap}: session cap reached."))
                break

            meta, body, _ = fl.read_job(mission_path)  # re-read: status editable mid-run
            status = (meta.get("status") or "active").strip().lower()
            if status != "active":
                fl.info(fl.green(f"mission status is '{status}'. Stopping."))
                break
            if run_done_check(done_check):
                fl.info(fl.green("done-check passed — mission complete."))
                fl.set_frontmatter_field(mission_path, "status", "done")
                break

            dirty = dirty_tree(job_dir, stem)
            if dirty:
                if fresh_started == 0 and iteration > 0:
                    # Previous session was interrupted mid-iteration — its in-flight
                    # work IS the dirt. Route to the retry path: the continuation
                    # prompt inspects git status and decides finish / revert / skip.
                    fl.info(fl.yellow(
                        f"↻ dirty tree from a previous session's interrupted iteration "
                        f"#{iteration} — auto-resuming via the retry path:"))
                    for line in dirty:
                        fl.info(fl.dim(f"    {line}"))
                    write_attempt(mission_path, job_dir, 1)
                    continue
                fl.info(fl.red(
                    f"✗ working tree dirty — refusing to start iteration #{iteration + 1}:"))
                for line in dirty:
                    fl.info(fl.dim(f"    {line}"))
                fl.info(
                    "  Commit or stash, then re-launch. If this IS a previous attempt's "
                    "in-flight work you want the grinder to resume, write 1 to "
                    f"`{_state_path(mission_path, job_dir, 'attempt')}` and re-launch — "
                    "the retry continuation prompt will decide commit/revert.")
                break

            iteration += 1
            fresh_started += 1
            # persist the counter BEFORE launching — a crash/Ctrl+C mid-iteration must not
            # produce duplicate iteration numbers/tags on the next run
            write_iter(mission_path, job_dir, iteration)
            prompt = compose_prompt(mission_path, body, meta, iteration, topic, mem_log)
            fl.info(fl.bold(f"▶ iteration #{iteration}")
                    + fl.dim(f"  (model {model}, topic {topic}, attempt 1/{MAX_ITER_ATTEMPTS})"))
        else:
            # ── retry of the in-flight iteration: skip pre-flight, keep the number ──
            meta, body, _ = fl.read_job(mission_path)
            prompt = compose_retry_prompt(mission_path, body, meta, iteration, topic,
                                          mem_log, attempt)
            fl.info(fl.bold(f"↻ iteration #{iteration}")
                    + fl.dim(f"  (model {model}, topic {topic}, "
                             f"attempt {attempt + 1}/{MAX_ITER_ATTEMPTS} — continuation)"))

        with open(runner_log, "a", encoding="utf-8") as rl:
            rl.write(f"[{fl.human_now()}] iter {iteration} attempt {attempt + 1} model={model}\n")

        code, elapsed, transient, timed_out = fl.run_claude_job(
            prompt, model, fl.DEFAULT_PERMISSION_MODE, transcript_log, jsonl_path,
            env_extra={"GRIND_ITERATION": str(iteration), "GRIND_TOPIC": topic,
                       "GRIND_ATTEMPT": str(attempt + 1)},
            effort=(meta.get("effort") or "").strip() or None,
            max_turns=fl.coerce_int(meta, "max-turns", 0) or None,
            timeout_secs=iter_timeout or None,
        )
        if timed_out:
            fl.info(fl.red(f"  ⏱ watchdog killed iteration #{iteration} after "
                           f"{int(elapsed)}s (cap {int(iter_timeout)}s)"))
        fl.info((fl.green if code == 0 else fl.red)(f"  → exit {code} ({int(elapsed)}s)"))

        # ── productivity gate — independent of exit code ─────────────────────
        committed = tagged_commit_exists(topic, iteration)
        meta_after, _, _ = fl.read_job(mission_path)
        status_after = (meta_after.get("status") or "active").strip().lower()
        dirty_after = dirty_tree(job_dir, stem)
        tree_clean = not dirty_after  # None (no git) counts as clean — gate needs git anyway

        if tree_clean and (committed or status_after != "active"):
            # productive: tagged commit landed or status flipped, nothing left dangling
            fl.info(fl.green(f"  ✓ iteration #{iteration} productive "
                             f"(commit tagged or status flipped; tree clean)"))
            write_attempt(mission_path, job_dir, 0)
            transient_retries = 0
            with open(runner_log, "a", encoding="utf-8") as rl:
                rl.write(f"[{fl.human_now()}]   productive exit={code} {int(elapsed)}s\n")
        elif tree_clean and status_after == "active" and \
                (timed_out or transient or elapsed < FAST_FAIL_SECS):
            # transient: watchdog kill, API-error signature, or instant crash with no
            # work landed — long backoff, same iteration + attempt (budget untouched)
            transient_retries += 1
            if transient_retries > MAX_TRANSIENT_RETRIES:
                fl.info(fl.red(
                    f"  ✘ sustained transient-API failure — {MAX_TRANSIENT_RETRIES} long "
                    f"backoffs exhausted. Stopping; state preserved "
                    f"(.iter={iteration} .attempt={attempt}) — re-launch when it clears."))
                break
            reason = ("watchdog timeout" if timed_out
                      else "transient API error in output" if transient
                      else f"fast failure ({int(elapsed)}s)")
            fl.info(fl.yellow(f"  ⏸ {reason} — no work landed; long backoff "
                              f"{transient_retries}/{MAX_TRANSIENT_RETRIES} "
                              "(attempt budget untouched)"))
            fl.long_backoff_sleep(transient_retries)
            pending_prompt = prompt  # relaunch the SAME iteration + attempt
            continue
        else:
            # real unproductive attempt: meaningful time, no tagged commit / dirty tree
            transient_retries = 0
            next_attempt = attempt + 1
            if next_attempt < MAX_ITER_ATTEMPTS:
                write_attempt(mission_path, job_dir, next_attempt)
                why = ("dirty tree (partial in-flight work)" if not tree_clean
                       else "no tagged commit")
                fl.info(fl.yellow(
                    f"  ↻ iteration #{iteration} unproductive — {why}; will retry with the "
                    f"continuation prompt (attempt {next_attempt + 1}/{MAX_ITER_ATTEMPTS})"))
                time.sleep(iter_pause)
                continue
            fl.info(fl.red(
                f"  ✘ iteration #{iteration} exhausted all {MAX_ITER_ATTEMPTS} attempts. "
                "Stopping for triage — inspect `git status`, then either commit the "
                f"partial work with the `(grind: {topic} #{iteration})` tag, or revert it "
                f"and write 0 to `{_state_path(mission_path, job_dir, 'attempt')}`; "
                "then re-launch."))
            break

        # ── post-productive checks ───────────────────────────────────────────
        if run_done_check(done_check):
            fl.info(fl.green("done-check passed — mission complete."))
            fl.set_frontmatter_field(mission_path, "status", "done")
            break
        if status_after == "done":
            fl.info(fl.green("mission flipped itself to done."))
            break
        time.sleep(iter_pause)

    fl.info(fl.green(f"\ngrind finished — {iteration} iteration(s) run."))


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        fl.info("\ninterrupted (iteration + attempt counters saved; re-run to resume, "
                "--reset to restart).")
        sys.exit(130)
