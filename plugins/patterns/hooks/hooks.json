{
  "description": "patterns plugin — mechanize the pattern-gating rule: hard-block edits governed only by non-blessed patterns (PreToolUse), and remind which pattern checklists govern an edited path + auto-regenerate the routes table on registry changes (PostToolUse)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pattern-guards.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pattern-guards.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
