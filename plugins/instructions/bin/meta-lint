#!/usr/bin/env python3
"""meta-lint — config-driven health check for a project's agent-instruction system.

The ENGINE ships here (instructions@opsi); each project supplies the POLICY via
`.agent/meta-lint.json`. No config file → silent no-op, exit 0 (projects opt IN). A minimal
`{}` config lints the opsi house layout (`.agent/` + `.claude/`) with the default caps; every
knob — enabled checks, cap numbers AND units (lines vs chars), directory layout, filename
conventions, dup tripwires, boards, audit stamp, generated files, allow-length marker — is
overridable in the config. Where a config exists, this engine supersedes the caps.sh hook
(caps.sh skips itself).

    meta-lint             # full run, grouped findings, exit 1 on findings (advisory)
    meta-lint --fast      # one-line summary, exit 0 (SessionStart pulse; the hook wiring's
                          #   `|| echo` loud-DISARM fallback fires only on real failure)
    meta-lint --test      # self-test against a synthetic tree
    meta-lint --config P  # explicit config path (bypasses the .agent/meta-lint.json gate)
    meta-lint --root D    # lint D (default: $CLAUDE_PROJECT_DIR, else cwd)

Checks (pick per-project via "checks"; all default-on, each no-ops when its dir is absent):
  [cross-ref]     markdown links in meta files resolve
  [lessons-index] lessons/ files ⇄ README index in sync
  [lessons-prio]  every lesson has exactly one High/Mid/Low home; tier caps; High ↑stamps fresh
  [agents]        agent frontmatter sane + no orphan agents nothing references
  [skills]        every skill dir mentioned in CLAUDE.md's index
  [commands]      slash-command wrapper ⇄ skill parity, wrappers thin + delegating
  [routes]        pattern-routes.tsv matches regeneration from pattern frontmatter
  [gen]           generated files keep their GENERATED header
  [filenames]     timestamped naming in plan/loop/grind/reviews/milestone dirs
  [skill-fm]      SKILL.md frontmatter present, name matches folder
  [dup]           canonical-rule duplication tripwires (regex → canonical file)
  [stale]         handoff age
  [board]         accumulating files keep the live zone lean
  [reference]     blessed-pattern Reference pointers still exist
  [size]          per-file caps (lines OR chars per entry) + allow-length marker (capped)
  [count]         artifact counts (plans, lessons, milestones, skills, agents, rules, hooks, .todo)
  [audit]         `Last audit:` stamp freshness

Escape hatch: META_LINT_OFF=1. Python3 stdlib only. ADVISORY by design: exit 1 on findings so
scripts can branch, but nothing should consume it as a blocker.
"""

from __future__ import annotations

import fnmatch
import glob as globmod
import json
import os
import re
import subprocess
import sys
import time

sys.dont_write_bytecode = True

CONFIG_REL = os.path.join(".agent", "meta-lint.json")

DEFAULTS: dict = {
    "checks": [
        "cross-ref", "lessons-index", "lessons-prio", "agents", "skills", "commands",
        "routes", "gen", "filenames", "skill-fm", "dup", "stale", "board", "reference",
        "size", "count", "audit",
    ],
    # path filtering for the meta-file walk
    "skip_dir_parts": ["archive", "worktrees", "node_modules", ".git", "reviews"],
    "archive_file_regex": r"-archive\.md$",
    "content_dir_prefixes": [
        ".agent/plan/", ".agent/loop/", ".agent/grind/", ".agent/milestone/", ".agent/patterns/",
    ],
    "crossref_roots": [
        "CLAUDE.md", "AGENTS.md", ".agent", ".claude/skills", ".claude/agents", ".claude/commands",
    ],
    "layout": {
        "plan": ".agent/plan",
        "loop": ".agent/loop",
        "grind": ".agent/grind",
        "reviews": ".agent/reviews",
        "milestone": ".agent/milestone",
        "lessons": ".agent/lessons",
        "patterns": ".agent/patterns",
        "skills": ".claude/skills",
        "agents": ".claude/agents",
        "commands": ".claude/commands",
        "rules": ".claude/rules",
        "hooks": ".claude/hooks",
        "handoff": ".agent/handoff.md",
        "todo": ".todo",
        "claude_md": "CLAUDE.md",
    },
    # size caps — each entry: {"path": exact-or-glob, "cap": N, "unit": "chars"|"lines"}.
    # Most-specific entry wins per unit (exact > longer glob), so a file can carry one line
    # cap AND one char cap. Defaults mirror the caps.sh hook (chars).
    "size": {
        "caps": [
            {"path": "CLAUDE.md", "cap": 6000, "unit": "chars"},
            {"path": "AGENTS.md", "cap": 6000, "unit": "chars"},
            {"path": ".agent/handoff.md", "cap": 4000, "unit": "chars"},
            {"path": ".agent/instructions-changelog.md", "cap": 8000, "unit": "chars"},
            {"path": ".agent/lessons/README.md", "cap": 8000, "unit": "chars"},
            {"path": ".agent/lessons/*.md", "cap": 4000, "unit": "chars"},
            {"path": ".claude/skills/*/SKILL.md", "cap": 9000, "unit": "chars"},
            {"path": ".claude/agents/*.md", "cap": 4000, "unit": "chars"},
            {"path": ".claude/rules/*.md", "cap": 2000, "unit": "chars"},
            {"path": ".claude/commands/*.md", "cap": 800, "unit": "chars"},
        ],
        "allow_marker": "meta-lint: allow-length",
        "max_allows": 5,
    },
    # count caps — null/0 disables one; absent dirs are skipped anyway
    "counts": {
        "plan_active_max": 25,
        "lessons_max": 80,
        "milestones_active_max": 6,
        "todo_active_zone_max_lines": 120,
        "todo_zone_break": "# TMP NOTES",
        "skills_max": 12,
        "agents_max": 6,
        "rules_max": 10,
        "hook_files_max": 12,
    },
    "lessons_priority": {"high_max": 10, "mid_max": 35, "confirm_max_age_days": 90},
    # dup tripwires: {"pattern": regex, "canonical": file, "allowed": [files]}; a hit outside
    # canonical/allowed/exempt means a rule body got copied instead of pointed to
    "dup": {"rules": [], "exempt": []},
    "boards": {
        "files": [".agent/worktrees.md"],
        "narrative_prefix": "_(",
        "narrative_max_lines": 150,
        "narrative_max_age_days": 30,
    },
    "stale": {"handoff_max_age_days": 7},
    "audit": {
        "file": ".agent/instructions-changelog.md",
        "regex": r"^Last audit:\s*(\d{4})-(\d{2})-(\d{2})\s*$",
        "max_age_days": 30,
        "require": False,  # true → a missing stamp/file is itself a finding
    },
    "generated": {"files": [".agent/patterns/pattern-routes.tsv"], "marker": "GENERATED"},
    "filenames": {
        "rules": [
            {"dirs": [".agent/plan", ".agent/loop", ".agent/grind"], "target": "files",
             "regex": r"^\d{6}_\d{6}_.+\.(md|log)$", "allow": [r"^runner_\d{6}_\d{6}\.log$"],
             "label": "YYMMDD_HHMMSS_{topic}"},
            {"dirs": [".agent/reviews"], "target": "files",
             "regex": r"^\d{6}_.+\.md$", "allow": [], "label": "YYMMDD_{topic}.md"},
            {"dirs": [".agent/milestone"], "target": "dirs",
             "regex": r"^\d{6}_.+", "allow": [r"^archive$"], "label": "YYMMDD_{slug}"},
        ],
    },
    "reference": {"prefixes": ["packages/", "apps/", "bin/", ".docs/", ".claude/", ".agent/"]},
    "routes": {"tsv": ".agent/patterns/pattern-routes.tsv"},
}

MD_LINK_RX = re.compile(r"\[[^\]]*\]\(([^)\s]+)\)")


def merge(base, override):
    if isinstance(base, dict) and isinstance(override, dict):
        out = dict(base)
        for k, v in override.items():
            out[k] = merge(base[k], v) if k in base else v
        return out
    return override  # lists and scalars replace wholesale


def load_config(path: str) -> dict:
    with open(path, encoding="utf-8") as f:
        user = json.load(f)
    if not isinstance(user, dict):
        raise ValueError("config root must be a JSON object")
    return merge(DEFAULTS, user)


def skip_path(rel: str, cfg: dict) -> bool:
    parts = rel.split(os.sep)
    if any(p in cfg["skip_dir_parts"] for p in parts[:-1]):
        return True
    if rel.startswith(tuple(cfg["content_dir_prefixes"])):
        return True
    return bool(re.search(cfg["archive_file_regex"], parts[-1]))


def meta_md_files(root: str, cfg: dict) -> list[str]:
    out: list[str] = []
    for entry in cfg["crossref_roots"]:
        ap = os.path.join(root, entry)
        if os.path.isfile(ap):
            out.append(entry)
            continue
        for dirpath, dirnames, filenames in os.walk(ap):
            dirnames[:] = [d for d in dirnames if d not in cfg["skip_dir_parts"]]
            for name in filenames:
                if not name.endswith(".md"):
                    continue
                rel = os.path.relpath(os.path.join(dirpath, name), root)
                if not skip_path(rel, cfg):
                    out.append(rel)
    return sorted(set(out))


def check_crossrefs(root: str, cfg: dict) -> list[str]:
    findings = []
    for rel in meta_md_files(root, cfg):
        base = os.path.dirname(os.path.join(root, rel))
        in_fence = False
        try:
            with open(os.path.join(root, rel), encoding="utf-8") as f:
                for lineno, line in enumerate(f, 1):
                    if line.lstrip().startswith("```"):
                        in_fence = not in_fence
                        continue
                    if in_fence:
                        continue  # illustrative snippets, not live links
                    # Links inside inline code spans are templates/examples. Normalize
                    # backtick-wrapped link labels ([`x`](y) → [x](y)) first, then drop
                    # everything inside remaining code spans via backtick parity.
                    normalized = re.sub(r"\[`([^`\]]*)`\]", r"[\1]", line)
                    live = "".join(seg for i, seg in enumerate(normalized.split("`")) if i % 2 == 0)
                    for target in MD_LINK_RX.findall(live):
                        t = target.split("#", 1)[0]
                        if not t or t.startswith(("http://", "https://", "mailto:")):
                            continue
                        if any(c in t for c in "*{<") or "YYMMDD" in t:
                            continue  # template / glob, not a real path
                        cand = os.path.normpath(os.path.join(base, t))
                        alt = os.path.normpath(os.path.join(root, t))
                        if not os.path.exists(cand) and not os.path.exists(alt):
                            findings.append(f"[cross-ref] {rel}:{lineno} → `{target}` does not exist")
        except OSError:
            continue
    return findings


def check_lessons_index(root: str, cfg: dict) -> list[str]:
    findings = []
    lrel = cfg["layout"]["lessons"]
    ldir = os.path.join(root, lrel)
    if not os.path.isdir(ldir):
        return []
    files = {n for n in os.listdir(ldir) if n.endswith(".md") and n != "README.md"}
    try:
        with open(os.path.join(ldir, "README.md"), encoding="utf-8") as f:
            index = f.read()
    except OSError:
        return [f"[lessons-index] {lrel}/README.md unreadable"]
    linked = set(re.findall(r"\]\(([a-z0-9.-]+\.md)\)", index))
    for missing in sorted(files - linked):
        findings.append(f"[lessons-index] {missing} exists but is not linked in {lrel}/README.md")
    for ghost in sorted(linked - files):
        findings.append(f"[lessons-index] README links {ghost} but the file does not exist")
    return findings


def check_lessons_priority(root: str, cfg: dict) -> list[str]:
    findings = []
    lrel = cfg["layout"]["lessons"]
    ldir = os.path.join(root, lrel)
    prio = cfg["lessons_priority"]
    try:
        with open(os.path.join(ldir, "README.md"), encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return []
    files = {n for n in os.listdir(ldir) if n.endswith(".md") and n != "README.md"}
    link_rx = re.compile(r"\]\(([a-z0-9.-]+\.md)\)")
    sections: dict[str, list[str]] = {"high": [], "mid": [], "low": []}
    high_lines: list[str] = []
    current = None
    for line in text.splitlines():
        m = re.match(r"^##\s+(.*)$", line)
        if m:
            h = m.group(1).lower()
            current = "high" if "high" in h else "mid" if "mid" in h else "low" if "low" in h else None
            continue
        if current:
            hits = link_rx.findall(line)
            sections[current].extend(hits)
            if current == "high" and hits:
                high_lines.append(line)
    if not any(sections.values()):
        return [f"[lessons-prio] {lrel}/README.md has no High/Mid/Low priority sections"]
    homes: dict[str, int] = {}
    for sec in sections.values():
        for name in sec:
            homes[name] = homes.get(name, 0) + 1
    for name in sorted(files):
        n = homes.get(name, 0)
        if n == 0:
            findings.append(f"[lessons-prio] {name} has no priority home (High/Mid/Low) in the index")
        elif n > 1:
            findings.append(f"[lessons-prio] {name} appears in {n} priority sections — exactly one")
    if len(set(sections["high"])) > prio["high_max"]:
        findings.append(
            f"[lessons-prio] High holds {len(set(sections['high']))} lessons (cap {prio['high_max']}) "
            "— promotion requires demotion (lessons skill § Priority router)"
        )
    if len(set(sections["mid"])) > prio["mid_max"]:
        findings.append(
            f"[lessons-prio] Mid holds {len(set(sections['mid']))} lessons (cap {prio['mid_max']}) "
            "— demote to Low or fold (lessons skill § Priority router)"
        )
    max_age = prio["confirm_max_age_days"]
    cutoff = time.time() - max_age * 86400
    for line in high_lines:
        name = link_rx.search(line).group(1)  # guarded: high_lines only holds link-bearing lines
        m = re.search(r"↑(\d{2})(\d{2})(\d{2})", line)
        if not m:
            findings.append(f"[lessons-prio] High entry {name} missing its `↑YYMMDD` confirmation marker")
            continue
        try:
            ts = time.mktime((2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)), 0, 0, 0, 0, 0, -1))
        except (ValueError, OverflowError):
            continue
        if ts < cutoff:
            findings.append(
                f"[lessons-prio] High entry {name} unconfirmed since {m.group(0)[1:]} "
                f"(>{max_age}d) — re-confirm or demote to Mid"
            )
    return findings


def check_agents(root: str, cfg: dict) -> list[str]:
    """Agents need frontmatter AND wiring — an orphan agent nothing references is dead weight."""
    findings = []
    arel = cfg["layout"]["agents"]
    adir = os.path.join(root, arel)
    if not os.path.isdir(adir):
        return []
    hay = []
    for rel in meta_md_files(root, cfg):
        if rel.startswith(arel + "/"):
            continue
        try:
            with open(os.path.join(root, rel), encoding="utf-8") as f:
                hay.append(f.read())
        except OSError:
            continue
    haystack = "\n".join(hay)
    for name in sorted(os.listdir(adir)):
        if not name.endswith(".md"):
            continue
        stem = name[:-3]
        with open(os.path.join(adir, name), encoding="utf-8") as f:
            text = f.read()
        if not re.match(r"\A---\n.*?^description:", text, re.DOTALL | re.MULTILINE):
            findings.append(f"[agents] {name}: missing frontmatter `description:`")
        if stem not in haystack:
            findings.append(
                f"[agents] {stem} is referenced by no skill/rule book/CLAUDE.md — wire it or delete it"
            )
    return findings


def check_skills_symmetry(root: str, cfg: dict) -> list[str]:
    """Every skill dir must be mentioned in CLAUDE.md's index (names are prose there, not links,
    so the cross-ref check can't see them)."""
    findings = []
    sdir = os.path.join(root, cfg["layout"]["skills"])
    if not os.path.isdir(sdir):
        return []
    try:
        with open(os.path.join(root, cfg["layout"]["claude_md"]), encoding="utf-8") as f:
            claude_md = f.read()
    except OSError:
        return []
    for name in sorted(os.listdir(sdir)):
        if not os.path.isdir(os.path.join(sdir, name)):
            continue
        if name not in claude_md:
            findings.append(
                f"[skills] `{name}` skill exists but {cfg['layout']['claude_md']}'s index never mentions it"
            )
    return findings


def check_commands(root: str, cfg: dict) -> list[str]:
    """Slash-command wrappers: one per skill, logic-free (the size cap enforces thinness).
    Symmetry both ways — a wrapper without a skill is dead; a skill without a wrapper is
    invisible in the slash picker."""
    findings = []
    cdir = os.path.join(root, cfg["layout"]["commands"])
    sdir = os.path.join(root, cfg["layout"]["skills"])
    if not os.path.isdir(cdir) or not os.path.isdir(sdir):
        return []
    skills = {n for n in os.listdir(sdir) if os.path.isdir(os.path.join(sdir, n))}
    wrappers = {n[:-3] for n in os.listdir(cdir) if n.endswith(".md")}
    for stray in sorted(wrappers - skills):
        findings.append(f"[commands] {stray}.md wraps no existing skill — delete or add the skill")
    for missing in sorted(skills - wrappers):
        findings.append(
            f"[commands] skill `{missing}` has no {cfg['layout']['commands']}/{missing}.md wrapper "
            "(invisible in the slash picker)"
        )
    for name in sorted(wrappers & skills):
        with open(os.path.join(cdir, name + ".md"), encoding="utf-8") as f:
            text = f.read()
        if not re.match(r"\A---\n.*?^description:", text, re.DOTALL | re.MULTILINE):
            findings.append(f"[commands] {name}.md missing frontmatter `description:`")
        if "Skill tool" not in text:
            findings.append(
                f"[commands] {name}.md must delegate to the Skill tool — wrappers carry no logic"
            )
    return findings


def parse_pattern_frontmatter(text: str):
    """Return (status, paths[], route) from the leading frontmatter block, tolerant of extra keys.
    Mirrors the patterns plugin's generate-pattern-routes.py parser — keep in sync."""
    m = re.match(r"\A---\n(.*?)\n---\n", text, re.DOTALL)
    if not m:
        return None, [], None
    status = None
    route = None
    paths: list[str] = []
    in_paths = False
    for line in m.group(1).splitlines():
        if re.match(r"^status:\s*\S", line):
            status = line.split(":", 1)[1].strip()
            in_paths = False
        elif re.match(r"^route:\s*\S", line):
            route = line.split(":", 1)[1].strip()
            in_paths = False
        elif re.match(r"^paths:\s*$", line):
            in_paths = True
        elif in_paths:
            pm = re.match(r'^\s+-\s+"?([^"]+?)"?\s*$', line)
            if pm:
                paths.append(pm.group(1))
            else:
                in_paths = False
        elif re.match(r"^\S", line):
            in_paths = False
    return status, paths, route


def check_routes(root: str, cfg: dict) -> list[str]:
    """The registry-colocated TSV must match the pattern frontmatter (status/paths/route) exactly."""
    prel = cfg["layout"]["patterns"]
    patterns_dir = os.path.join(root, prel)
    if not os.path.isdir(patterns_dir):
        return []
    tsv_rel = cfg["routes"]["tsv"]
    tsv_path = os.path.join(root, tsv_rel)
    findings = []
    expected = []
    for name in sorted(os.listdir(patterns_dir)):
        if not name.endswith(".md") or name == "README.md":
            continue
        with open(os.path.join(patterns_dir, name), encoding="utf-8") as f:
            status, paths, route = parse_pattern_frontmatter(f.read())
        if status is None or not paths:
            continue
        route = route or "edit"
        if route not in ("edit", "land"):
            findings.append(f"[routes] {prel}/{name}: unknown `route: {route}` (edit|land)")
            continue
        for glob in paths:
            expected.append(f"{glob}\t{prel}/{name}\t{status}\t{route}")
    try:
        with open(tsv_path, encoding="utf-8") as f:
            actual = [l.rstrip("\n") for l in f if l.strip() and not l.startswith("#")]
    except OSError:
        if not expected:
            return findings  # project doesn't use routed patterns — nothing to sync
        return findings + [
            f"[routes] {tsv_rel} missing — regenerate via the patterns plugin's "
            "generate-pattern-routes.py and commit the TSV"
        ]
    if actual != expected:
        findings.append(
            f"[routes] {tsv_rel} is STALE vs pattern frontmatter "
            f"({len(actual)} rows on disk, {len(expected)} expected) — regenerate and commit the TSV"
        )
    return findings


def check_generated_headers(root: str, cfg: dict) -> list[str]:
    findings = []
    marker = cfg["generated"]["marker"]
    for rel in cfg["generated"]["files"]:
        try:
            with open(os.path.join(root, rel), encoding="utf-8") as f:
                first = f.readline()
            if marker not in first:
                findings.append(f"[gen] {rel} lost its {marker} header")
        except OSError:
            pass  # missing generated file is another check's problem (e.g. [routes])
    return findings


def check_filenames(root: str, cfg: dict) -> list[str]:
    findings = []
    for rule in cfg["filenames"]["rules"]:
        rx = re.compile(rule["regex"])
        allow = [re.compile(a) for a in rule.get("allow", [])]
        want_dirs = rule.get("target", "files") == "dirs"
        for d in rule["dirs"]:
            ap = os.path.join(root, d)
            if not os.path.isdir(ap):
                continue
            for name in os.listdir(ap):
                if name.startswith("."):
                    continue
                is_dir = os.path.isdir(os.path.join(ap, name))
                if is_dir != want_dirs:
                    continue
                if any(a.match(name) for a in allow):
                    continue
                if not rx.match(name):
                    suffix = "/" if want_dirs else ""
                    findings.append(f"[filenames] {d}/{name}{suffix} violates {rule['label']} naming")
    return findings


def check_skill_frontmatter(root: str, cfg: dict) -> list[str]:
    findings = []
    srel = cfg["layout"]["skills"]
    sdir = os.path.join(root, srel)
    if not os.path.isdir(sdir):
        return []
    for name in sorted(os.listdir(sdir)):
        skill = os.path.join(sdir, name, "SKILL.md")
        if not os.path.isfile(skill):
            if os.path.isdir(os.path.join(sdir, name)):
                findings.append(f"[skill-fm] {srel}/{name}/ has no SKILL.md")
            continue
        with open(skill, encoding="utf-8") as f:
            text = f.read()
        m = re.match(r"\A---\n(.*?)\n---\n", text, re.DOTALL)
        if not m:
            findings.append(f"[skill-fm] {name}: SKILL.md has no frontmatter block")
            continue
        fm = m.group(1)
        if not re.search(r"^description:", fm, re.MULTILINE):
            findings.append(f"[skill-fm] {name}: frontmatter missing `description:`")
        nm = re.search(r"^name:\s*(\S+)", fm, re.MULTILINE)
        if nm and nm.group(1) != name:
            findings.append(f"[skill-fm] {name}: frontmatter name `{nm.group(1)}` ≠ folder name")
    return findings


def check_duplication(root: str, cfg: dict) -> list[str]:
    findings = []
    files = meta_md_files(root, cfg)
    exempt = set(cfg["dup"]["exempt"])
    for rule in cfg["dup"]["rules"]:
        rx = re.compile(rule["pattern"])
        canonical = rule["canonical"]
        allowed = set(rule.get("allowed", []))
        hits = []
        for rel in files:
            try:
                with open(os.path.join(root, rel), encoding="utf-8") as f:
                    if rx.search(f.read()):
                        hits.append(rel)
            except OSError:
                continue
        for rel in hits:
            if rel != canonical and rel not in allowed and rel not in exempt:
                findings.append(
                    f"[dup] {rel} carries a rule body canonical to {canonical} — replace with a pointer"
                )
    return findings


def git_age_days(root: str, rel: str):
    try:
        out = subprocess.run(
            ["git", "-C", root, "log", "-1", "--format=%ct", "--", rel],
            capture_output=True,
            text=True,
            timeout=10,
        ).stdout.strip()
        if out:
            return (time.time() - int(out)) / 86400
    except Exception:
        pass
    try:
        return (time.time() - os.path.getmtime(os.path.join(root, rel))) / 86400
    except OSError:
        return None


def check_staleness(root: str, cfg: dict) -> list[str]:
    findings = []
    handoff = cfg["layout"]["handoff"]
    max_days = cfg["stale"]["handoff_max_age_days"]
    if not os.path.isfile(os.path.join(root, handoff)):
        return []
    age = git_age_days(root, handoff)
    if age is not None and age > max_days:
        findings.append(
            f"[stale] {handoff} last touched {age:.0f}d ago (cap {max_days}d) — "
            "regenerate via the handoff skill at next session close"
        )
    return findings


def check_boards(root: str, cfg: dict) -> list[str]:
    findings = []
    b = cfg["boards"]
    cutoff = time.time() - b["narrative_max_age_days"] * 86400
    for rel in b["files"]:
        ap = os.path.join(root, rel)
        try:
            with open(ap, encoding="utf-8") as f:
                lines = f.readlines()
        except OSError:
            continue
        narrative = [l for l in lines if l.lstrip().startswith(b["narrative_prefix"])]
        if len(narrative) > b["narrative_max_lines"]:
            findings.append(
                f"[board] {rel}: {len(narrative)} narrative lines (cap {b['narrative_max_lines']}) — "
                f"move history to {rel.removesuffix('.md')}-archive.md"
            )
        for l in narrative:
            for ds in re.findall(r"(20\d{2})-(\d{2})-(\d{2})", l):
                try:
                    ts = time.mktime((int(ds[0]), int(ds[1]), int(ds[2]), 0, 0, 0, 0, 0, -1))
                except (ValueError, OverflowError):
                    continue
                if ts < cutoff:
                    findings.append(
                        f"[board] {rel}: narrative entry dated {'-'.join(ds)} is older than "
                        f"{b['narrative_max_age_days']}d — archive it"
                    )
                    break
            else:
                continue
            break
    return findings


def check_reference_lines(root: str, cfg: dict) -> list[str]:
    findings = []
    prel = cfg["layout"]["patterns"]
    pdir = os.path.join(root, prel)
    if not os.path.isdir(pdir):
        return []
    prefixes = tuple(cfg["reference"]["prefixes"])
    ref_rx = re.compile(r"^\s*(?:[-*]\s*)?\*{0,2}Reference\*{0,2}\s*:", re.IGNORECASE)
    path_rx = re.compile(r"`([^`]+)`")
    for name in sorted(os.listdir(pdir)):
        if not name.endswith(".md") or name == "README.md":
            continue
        with open(os.path.join(pdir, name), encoding="utf-8") as f:
            text = f.read()
        if not re.search(r"^status:\s*blessed\s*$", text[:500], re.MULTILINE):
            continue
        for lineno, line in enumerate(text.splitlines(), 1):
            if not ref_rx.match(line):
                continue
            for p in path_rx.findall(line):
                p = re.sub(r":[0-9:~a-zA-Z-]+$", "", p.strip())  # drop :line / :symbol suffix
                # Only repo-rooted pointers are checkable; package-relative soft refs are prose.
                if " " in p or any(c in p for c in "*{<"):
                    continue
                if not p.startswith(prefixes):
                    continue
                if not os.path.exists(os.path.join(root, p)):
                    findings.append(
                        f"[reference] {prel}/{name}:{lineno} → `{p}` gone "
                        "(body still governs; fix the pointer)"
                    )
    return findings


def has_allow_marker(path: str, marker: str) -> bool:
    try:
        with open(path, encoding="utf-8") as f:
            head = [next(f, "") for _ in range(12)]
        return any(marker in l for l in head)
    except OSError:
        return False


def caps_for(rel: str, caps: list[dict]) -> dict:
    """Most-specific cap entry wins PER UNIT (exact path > longer glob), so one file can carry
    both a line cap and a char cap."""
    best: dict[str, tuple[int, int, bool]] = {}  # unit -> (specificity, cap, exact)
    for e in caps:
        pat, cap, unit = e["path"], e["cap"], e.get("unit", "lines")
        if rel == pat:
            best[unit] = (10**9, cap, True)
        elif fnmatch.fnmatch(rel, pat):
            spec = len(pat.replace("*", ""))
            cur = best.get(unit)
            if cur is None or (not cur[2] and spec > cur[0]):
                best[unit] = (spec, cap, False)
    return {unit: cap for unit, (_, cap, _e) in best.items()}


def check_sizes(root: str, cfg: dict) -> list[str]:
    findings = []
    size_cfg = cfg["size"]
    marker = size_cfg["allow_marker"]
    allows = 0
    candidates: set[str] = set()
    for e in size_cfg["caps"]:
        pat = e["path"]
        if not any(c in pat for c in "*?["):
            candidates.add(pat)
            continue
        for ap in globmod.glob(os.path.join(root, pat)):
            candidates.add(os.path.relpath(ap, root))
    for rel in sorted(candidates):
        ap = os.path.join(root, rel)
        if not os.path.isfile(ap) or skip_path(rel, cfg):
            continue
        limits = caps_for(rel, size_cfg["caps"])
        if not limits:
            continue
        if has_allow_marker(ap, marker):
            allows += 1
            continue
        for unit, cap in limits.items():
            try:
                if unit == "chars":
                    n = os.path.getsize(ap)
                else:
                    with open(ap, encoding="utf-8") as f:
                        n = sum(1 for _ in f)
            except OSError:
                continue
            if n > cap:
                findings.append(
                    f"[size] {rel}: {n} {unit} (cap {cap}) — compact "
                    "(delete → fold → archive → split); never raise the cap to silence this"
                )
    if allows > size_cfg["max_allows"]:
        findings.append(
            f"[size] {allows} allow-length exceptions repo-wide (cap {size_cfg['max_allows']}) — "
            "exceptions are capped too; split the offenders"
        )
    return findings


def check_counts(root: str, cfg: dict) -> list[str]:
    findings = []
    c = cfg["counts"]
    lay = cfg["layout"]

    def over(key):
        return c.get(key) or None  # null/0/absent disables

    pdir = os.path.join(root, lay["plan"])
    cap = over("plan_active_max")
    if cap and os.path.isdir(pdir):
        n = sum(1 for f in os.listdir(pdir) if f.endswith(".md"))
        if n > cap:
            findings.append(
                f"[count] {lay['plan']}/ holds {n} active plans (cap {cap}) — archive closed "
                "plans per the plan skill (git mv to an archive/ subdir)"
            )
    ldir = os.path.join(root, lay["lessons"])
    cap = over("lessons_max")
    if cap and os.path.isdir(ldir):
        n = sum(1 for f in os.listdir(ldir) if f.endswith(".md") and f != "README.md")
        if n > cap:
            findings.append(
                f"[count] {n} lessons (cap {cap}) — run a consolidation pass via the lessons "
                "skill (merge duplicates, fold matured rules into their rule book, prune dead mechanics)"
            )
    mdir = os.path.join(root, lay["milestone"])
    cap = over("milestones_active_max")
    if cap and os.path.isdir(mdir):
        n = sum(
            1
            for d in os.listdir(mdir)
            if os.path.isdir(os.path.join(mdir, d)) and d != "archive" and not d.startswith(".")
        )
        if n > cap:
            findings.append(
                f"[count] {n} active milestones (cap {cap}) — close or archive via the milestone skill"
            )
    cap = over("todo_active_zone_max_lines")
    if cap:
        try:
            with open(os.path.join(root, lay["todo"]), encoding="utf-8") as f:
                zone = 0
                for line in f:
                    if line.startswith(c["todo_zone_break"]):
                        break
                    zone += 1
            if zone > cap:
                findings.append(
                    f"[count] {lay['todo']} active zone is {zone} lines (cap {cap}) — "
                    "run triage-todo (promote to milestone/plan/loop/grind, or drop)"
                )
        except OSError:
            pass
    sdir = os.path.join(root, lay["skills"])
    cap = over("skills_max")
    if cap and os.path.isdir(sdir):
        n = sum(1 for d in os.listdir(sdir) if os.path.isdir(os.path.join(sdir, d)))
        if n > cap:
            findings.append(f"[count] {n} skills (cap {cap}) — merge/retire before adding more (T3)")
    adir = os.path.join(root, lay["agents"])
    cap = over("agents_max")
    if cap and os.path.isdir(adir):
        n = sum(1 for f in os.listdir(adir) if f.endswith(".md"))
        if n > cap:
            findings.append(f"[count] {n} agents (cap {cap}) — merge/retire before adding more (T3)")
    rdir = os.path.join(root, lay["rules"])
    cap = over("rules_max")
    if cap and os.path.isdir(rdir):
        n = sum(1 for f in os.listdir(rdir) if f.endswith(".md"))
        if n > cap:
            findings.append(f"[count] {n} rules (cap {cap}) — merge/retire before adding more (T3)")
    hdir = os.path.join(root, lay["hooks"])
    cap = over("hook_files_max")
    if cap and os.path.isdir(hdir):
        n = sum(1 for f in os.listdir(hdir) if not f.startswith(".") and f != "__pycache__")
        if n > cap:
            findings.append(f"[count] {n} hook files (cap {cap}) — consolidate guards (T3)")
    return findings


def check_audit_freshness(root: str, cfg: dict) -> list[str]:
    """An audit run stamps `Last audit: YYYY-MM-DD` in the changelog; a stale or missing stamp
    means truth-checks haven't run."""
    a = cfg["audit"]
    path = os.path.join(root, a["file"])
    try:
        with open(path, encoding="utf-8") as f:
            text = f.read()
    except OSError:
        if a["require"]:
            return [f"[audit] {a['file']} missing — the change log + audit stamp live there"]
        return []
    m = re.search(a["regex"], text, re.MULTILINE)
    if not m:
        if a["require"]:
            return [f"[audit] {a['file']} has no `Last audit: YYYY-MM-DD` stamp"]
        return []
    try:
        ts = time.mktime((int(m.group(1)), int(m.group(2)), int(m.group(3)), 0, 0, 0, 0, 0, -1))
    except (ValueError, OverflowError, IndexError):
        return ["[audit] `Last audit:` stamp is not a valid date"]
    age = (time.time() - ts) / 86400
    if age > a["max_age_days"]:
        return [
            f"[audit] last instructions audit was {age:.0f}d ago (cap {a['max_age_days']}d) — "
            "run instructions-audit (mechanical + truth pass), stamp the changelog"
        ]
    return []


CHECKS = [
    ("cross-ref", check_crossrefs),
    ("lessons-index", check_lessons_index),
    ("lessons-prio", check_lessons_priority),
    ("agents", check_agents),
    ("skills", check_skills_symmetry),
    ("commands", check_commands),
    ("routes", check_routes),
    ("gen", check_generated_headers),
    ("filenames", check_filenames),
    ("skill-fm", check_skill_frontmatter),
    ("dup", check_duplication),
    ("stale", check_staleness),
    ("board", check_boards),
    ("reference", check_reference_lines),
    ("size", check_sizes),
    ("count", check_counts),
    ("audit", check_audit_freshness),
]


def run_all(root: str, cfg: dict) -> list[str]:
    enabled = set(cfg["checks"])
    findings: list[str] = []
    for name, check in CHECKS:
        if name not in enabled:
            continue
        try:
            findings.extend(check(root, cfg))
        except Exception as e:  # a broken check is itself a finding, never a crash
            findings.append(f"[meta-lint] check {name} crashed: {e}")
    return findings


def fast_summary(findings: list[str]) -> str:
    if not findings:
        return "meta: OK"
    counts: dict[str, int] = {}
    for f in findings:
        tag = f.split("]", 1)[0].lstrip("[")
        counts[tag] = counts.get(tag, 0) + 1
    parts = ", ".join(f"{n} {tag}" for tag, n in sorted(counts.items()))
    return f"meta: {len(findings)} finding(s) — {parts}. Run the meta-lint engine (instructions@opsi) for detail."


def run_tests() -> int:
    import shutil
    import tempfile

    root = tempfile.mkdtemp(prefix="meta-lint-test-")
    try:
        os.makedirs(os.path.join(root, ".agent", "lessons"))
        os.makedirs(os.path.join(root, ".claude", "skills", "good"))
        os.makedirs(os.path.join(root, ".claude", "skills", "bad"))
        os.makedirs(os.path.join(root, ".claude", "agents"))
        os.makedirs(os.path.join(root, ".claude", "hooks"))
        os.makedirs(os.path.join(root, ".agent", "patterns"))
        os.makedirs(os.path.join(root, ".agent", "plan"))
        os.makedirs(os.path.join(root, ".agent", "milestone", "bad-milestone"))
        os.makedirs(os.path.join(root, ".agent", "milestone", "archive"))
        with open(os.path.join(root, ".agent", "meta-lint.json"), "w") as f:
            json.dump(
                {
                    "size": {
                        "caps": [
                            {"path": ".agent/lessons/README.md", "cap": 170, "unit": "lines"},
                            {"path": ".agent/lessons/*.md", "cap": 80, "unit": "lines"},
                            {"path": ".agent/handoff.md", "cap": 4096, "unit": "chars"},
                            {"path": "fat-note.md", "cap": 100, "unit": "chars"},
                        ]
                    },
                    "audit": {"require": True},
                    "dup": {
                        "rules": [
                            {
                                "pattern": r"NEVER an ordinary \(non-FF\) merge",
                                "canonical": "CLAUDE.md",
                            }
                        ]
                    },
                },
                f,
            )
        with open(os.path.join(root, "CLAUDE.md"), "w") as f:
            f.write("[ok](.agent/instructions.md) [broken](.agent/nope.md)\n")
            f.write("```\n[fenced](.agent/fenced-example.md)\n```\n")
            f.write("Skills: **good**, **bad**. Agents: wired-agent.\n")
            f.write("NEVER an ordinary (non-FF) merge\n")  # canonical home — clean
        with open(os.path.join(root, ".agent", "instructions.md"), "w") as f:
            f.write("meta rulebook\n")
        with open(os.path.join(root, ".agent", "rulecopy.md"), "w") as f:
            f.write("copied: NEVER an ordinary (non-FF) merge\n")  # dup outside canonical
        with open(os.path.join(root, ".agent", "handoff.md"), "w") as f:
            f.write("fresh\n")
        with open(os.path.join(root, "fat-note.md"), "w") as f:
            f.write("x" * 150)  # over the 100-char cap
        with open(os.path.join(root, ".agent", "lessons", "indexed.md"), "w") as f:
            f.write("# L\n")
        with open(os.path.join(root, ".agent", "lessons", "orphan.md"), "w") as f:
            f.write("# L\n")
        with open(os.path.join(root, ".agent", "lessons", "README.md"), "w") as f:
            f.write("## High\n- [i](indexed.md) hook\n")  # no ↑ marker → flagged
            f.write("## Low\n- [g](ghost.md)\n")  # orphan.md gets no priority home
        with open(os.path.join(root, ".claude", "agents", "wired-agent.md"), "w") as f:
            f.write("---\nname: wired-agent\ndescription: fine\n---\nbody\n")
        with open(os.path.join(root, ".claude", "agents", "orphan-agent.md"), "w") as f:
            f.write("---\nname: orphan-agent\ndescription: fine\n---\nbody\n")
        os.makedirs(os.path.join(root, ".claude", "skills", "hidden"))
        with open(os.path.join(root, ".claude", "skills", "hidden", "SKILL.md"), "w") as f:
            f.write("---\nname: hidden\ndescription: fine\n---\nbody\n")
        os.makedirs(os.path.join(root, ".claude", "commands"))
        for wrapped in ("good", "bad", "hidden"):
            with open(os.path.join(root, ".claude", "commands", wrapped + ".md"), "w") as f:
                f.write(f"---\ndescription: w\n---\n\nInvoke the `{wrapped}` skill via the Skill tool.\n")
        with open(os.path.join(root, ".claude", "commands", "stray.md"), "w") as f:
            f.write("---\ndescription: w\n---\n\nInvoke the `stray` skill via the Skill tool.\n")
        with open(os.path.join(root, ".claude", "skills", "good", "SKILL.md"), "w") as f:
            f.write("---\nname: good\ndescription: fine\n---\nbody\n")
        with open(os.path.join(root, ".claude", "skills", "bad", "SKILL.md"), "w") as f:
            f.write("---\nname: wrong\n---\nbody\n")
        with open(os.path.join(root, ".agent", "patterns", "x-topic.md"), "w") as f:
            f.write('---\nstatus: blessed\nroute: land\npaths:\n  - "src/**"\n---\nReference: `packages/x/src/gone.ts`\n')
        with open(os.path.join(root, ".agent", "patterns", "pattern-routes.tsv"), "w") as f:
            f.write("# GENERATED\nstale/**\t.agent/patterns/x-topic.md\tblessed\tedit\n")
        with open(os.path.join(root, ".agent", "plan", "badname.md"), "w") as f:
            f.write("x\n")
        with open(os.path.join(root, ".agent", "plan", "runner_250101_120000.log"), "w") as f:
            f.write("runner log — allowed by the extra-allow regex\n")
        with open(os.path.join(root, ".agent", "lessons", "too-long.md"), "w") as f:
            f.write("# L\n" + "line\n" * 90)
        with open(os.path.join(root, ".agent", "lessons", "long-but-allowed.md"), "w") as f:
            f.write("# L\n<!-- meta-lint: allow-length — synthetic fixture -->\n" + "line\n" * 90)
        with open(os.path.join(root, ".agent", "lessons", "README.md"), "a") as f:
            f.write("- [t](too-long.md) [a](long-but-allowed.md)\n")  # appends into ## Low
        with open(os.path.join(root, ".todo"), "w") as f:
            f.write("item\n" * 130 + "# TMP NOTES\n" + "note\n" * 50)
        with open(os.path.join(root, ".agent", "instructions-changelog.md"), "w") as f:
            f.write("# log\n\nLast audit: 2020-01-01\n\n- old line\n")

        cfg = load_config(os.path.join(root, ".agent", "meta-lint.json"))
        findings = run_all(root, cfg)
        subset_cfg = merge(cfg, {"checks": ["size"]})
        subset = run_all(root, subset_cfg)

        empty = tempfile.mkdtemp(prefix="meta-lint-empty-")
        try:
            inactive = not os.path.isfile(os.path.join(empty, CONFIG_REL))
        finally:
            shutil.rmtree(empty, ignore_errors=True)

        want = [
            ("broken cross-ref", any("nope.md" in f for f in findings)),
            ("orphan lesson", any("orphan.md" in f for f in findings)),
            ("ghost index entry", any("ghost.md" in f for f in findings)),
            ("stale routes", any(f.startswith("[routes]") for f in findings)),
            ("bad skill name", any("bad:" in f and "≠ folder" in f for f in findings)),
            ("bad plan filename", any("badname.md" in f for f in findings)),
            ("runner log allowed", not any("runner_250101_120000.log" in f for f in findings)),
            ("bad milestone dirname", any("bad-milestone" in f for f in findings)),
            ("milestone archive allowed", not any("[filenames] .agent/milestone/archive" in f for f in findings)),
            ("dead reference line", any("gone.ts" in f for f in findings)),
            ("indexed lesson clean", not any("indexed.md exists but" in f for f in findings)),
            ("good skill clean", not any("[skill-fm] good" in f for f in findings)),
            ("fenced link skipped", not any("fenced-example" in f for f in findings)),
            ("oversized lesson flagged (lines)", any("too-long.md" in f and f.startswith("[size]") for f in findings)),
            ("oversized note flagged (chars)", any("fat-note.md" in f and "chars" in f for f in findings)),
            ("allow-length honored", not any("long-but-allowed.md" in f for f in findings)),
            (".todo zone overflow flagged", any("[count] .todo" in f for f in findings)),
            ("no-priority-home flagged", any("orphan.md has no priority home" in f for f in findings)),
            ("high missing ↑ marker flagged", any("indexed.md missing" in f for f in findings)),
            ("orphan agent flagged", any("orphan-agent is referenced by no" in f for f in findings)),
            ("wired agent clean", not any("wired-agent is referenced" in f for f in findings)),
            ("unlisted skill flagged", any("`hidden` skill exists but" in f for f in findings)),
            ("stray wrapper flagged", any("stray.md wraps no existing skill" in f for f in findings)),
            ("wrapped skills clean", not any("[commands] skill `good`" in f for f in findings)),
            ("stale audit stamp flagged", any(f.startswith("[audit]") and "ago" in f for f in findings)),
            ("dup tripwire flagged", any("[dup] .agent/rulecopy.md" in f for f in findings)),
            ("dup canonical home clean", not any("[dup] CLAUDE.md" in f for f in findings)),
            ("count caps quiet under limit", not any("[count]" in f and "skills" in f for f in findings)),
            ("checks subset honored", bool(subset) and all(f.startswith("[size]") for f in subset)),
            ("no config → inactive", inactive),
        ]
        fails = 0
        for name, ok in want:
            print(("ok " if ok else "FAIL ") + name)
            fails += 0 if ok else 1
        print(f"\n{fails} failure(s)")
        return 1 if fails else 0
    finally:
        import shutil

        shutil.rmtree(root, ignore_errors=True)


def main() -> int:
    argv = sys.argv[1:]
    if "--test" in argv:
        return run_tests()
    if os.environ.get("META_LINT_OFF") == "1":
        return 0

    def arg_after(flag):
        if flag in argv:
            i = argv.index(flag)
            if i + 1 < len(argv):
                return argv[i + 1]
        return None

    root = arg_after("--root") or os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()
    cfg_path = arg_after("--config")
    if cfg_path is None:
        cfg_path = os.path.join(root, CONFIG_REL)
        if not os.path.isfile(cfg_path):
            return 0  # project hasn't opted in — silent no-op
    try:
        cfg = load_config(cfg_path)
        findings = run_all(root, cfg)
    except Exception as e:
        findings = [f"[meta-lint] config {cfg_path} unusable: {e}"]
    if "--fast" in argv:
        # Pulse mode: findings ride the summary line; exit 0 so the hook wiring's `||` fallback
        # fires ONLY on real execution failure (the loud-DISARM contract), never on findings.
        print(fast_summary(findings))
        return 0
    if findings:
        for f in findings:
            print(f)
        print(f"\nmeta-lint: {len(findings)} finding(s) — advisory")
    else:
        print("meta-lint: clean")
    return 1 if findings else 0


if __name__ == "__main__":
    sys.exit(main())
