{
  "_comment": "RR (rabbit-run) meta-lint policy — the ratified caps/units/conventions from RR's bin/meta-lint, expressed as engine config. Drop in as .agent/meta-lint.json.",
  "checks": [
    "cross-ref", "lessons-index", "lessons-prio", "agents", "skills", "commands",
    "routes", "gen", "filenames", "skill-fm", "dup", "stale", "board", "reference",
    "size", "count", "audit"
  ],
  "skip_dir_parts": ["archive", "worktrees", "node_modules", ".git", "reviews"],
  "archive_file_regex": "-archive\\.md$",
  "content_dir_prefixes": [
    ".agent/plan/", ".agent/loop/", ".agent/grind/", ".agent/milestone/", ".agent/patterns/"
  ],
  "crossref_roots": [
    "CLAUDE.md", ".agent", ".claude/skills", ".claude/agents", ".claude/commands",
    ".docs/README.md", ".agent/patterns/README.md"
  ],
  "size": {
    "caps": [
      { "path": "CLAUDE.md", "cap": 120, "unit": "lines" },
      { "path": ".agent/start-here-chat.md", "cap": 120, "unit": "lines" },
      { "path": ".agent/start-here-loop.md", "cap": 140, "unit": "lines" },
      { "path": ".agent/start-here-grind.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/README.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/instructions-changelog.md", "cap": 120, "unit": "lines" },
      { "path": ".agent/workflow.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/conventions.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/autonomous-jobs.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/verify-your-work.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/instructions.md", "cap": 220, "unit": "lines" },
      { "path": ".agent/lessons/README.md", "cap": 170, "unit": "lines" },
      { "path": ".agent/lessons/*.md", "cap": 80, "unit": "lines" },
      { "path": ".claude/agents/*.md", "cap": 150, "unit": "lines" },
      { "path": ".claude/commands/*.md", "cap": 10, "unit": "lines" },
      { "path": ".claude/skills/*/SKILL.md", "cap": 500, "unit": "lines" },
      { "path": ".claude/skills/*/*.md", "cap": 200, "unit": "lines" },
      { "path": ".agent/patterns/README.md", "cap": 300, "unit": "lines" },
      { "path": ".agent/patterns/*.md", "cap": 600, "unit": "lines" },
      { "path": ".agent/handoff.md", "cap": 4096, "unit": "chars" }
    ],
    "allow_marker": "meta-lint: allow-length",
    "max_allows": 5
  },
  "counts": {
    "plan_active_max": 25,
    "lessons_max": 80,
    "milestones_active_max": 6,
    "todo_active_zone_max_lines": 120,
    "todo_zone_break": "# TMP NOTES",
    "skills_max": 24,
    "agents_max": 10,
    "rules_max": null,
    "hook_files_max": 12
  },
  "lessons_priority": { "high_max": 10, "mid_max": 35, "confirm_max_age_days": 90 },
  "dup": {
    "rules": [
      {
        "pattern": "\\|\\s*`draft`\\s*\\|\\s*author\\s*\\|",
        "canonical": ".agent/autonomous-jobs.md",
        "allowed": []
      },
      {
        "pattern": "NEVER an ordinary \\(non-FF\\) merge",
        "canonical": "CLAUDE.md",
        "allowed": []
      },
      {
        "pattern": "Loop / grind files use the 6\\+6 format",
        "canonical": ".agent/conventions.md",
        "allowed": []
      },
      {
        "pattern": "This is the canonical body\\. Every other file",
        "canonical": ".agent/patterns/README.md",
        "allowed": []
      }
    ],
    "exempt": [".agent/instructions.md"]
  },
  "boards": {
    "files": [".agent/worktrees.md"],
    "narrative_prefix": "_(",
    "narrative_max_lines": 150,
    "narrative_max_age_days": 30
  },
  "stale": { "handoff_max_age_days": 7 },
  "audit": {
    "file": ".agent/instructions-changelog.md",
    "regex": "^Last audit:\\s*(\\d{4})-(\\d{2})-(\\d{2})\\s*$",
    "max_age_days": 30,
    "require": true
  },
  "generated": { "files": [".agent/patterns/pattern-routes.tsv"], "marker": "GENERATED" },
  "filenames": {
    "rules": [
      {
        "dirs": [".agent/plan", ".agent/loop", ".agent/grind"],
        "target": "files",
        "regex": "^\\d{6}_\\d{6}_.+\\.(md|log)$",
        "allow": ["^runner_\\d{6}_\\d{6}\\.log$"],
        "label": "YYMMDD_HHMMSS_{topic}"
      },
      {
        "dirs": [".agent/reviews"],
        "target": "files",
        "regex": "^\\d{6}_.+\\.md$",
        "allow": [],
        "label": "YYMMDD_{topic}.md"
      },
      {
        "dirs": [".agent/milestone"],
        "target": "dirs",
        "regex": "^\\d{6}_.+",
        "allow": ["^archive$"],
        "label": "YYMMDD_{slug}"
      }
    ]
  },
  "reference": { "prefixes": ["packages/", "apps/", "bin/", ".docs/", ".claude/", ".agent/"] },
  "routes": { "tsv": ".agent/patterns/pattern-routes.tsv" },
  "layout": {
    "plan": ".agent/plan",
    "loop": ".agent/loop",
    "grind": ".agent/grind",
    "reviews": ".agent/reviews",
    "milestone": ".agent/milestone",
    "lessons": ".agent/lessons",
    "patterns": ".agent/patterns",
    "skills": ".claude/skills",
    "agents": ".claude/agents",
    "commands": ".claude/commands",
    "rules": ".claude/rules",
    "hooks": ".claude/hooks",
    "handoff": ".agent/handoff.md",
    "todo": ".todo",
    "claude_md": "CLAUDE.md"
  }
}
