{
  "description": "commit plugin — enforce the single-line commit message format on Bash git commits (PreToolUse), and nudge to commit uncommitted work at session end (Stop)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/commit-format.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/commit-nudge.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
